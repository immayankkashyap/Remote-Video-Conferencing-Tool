// This is your Prisma schema file for the frontend Next.js application.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id            String    @id @default(cuid())
  name          String?
  username      String?   @unique
  password      String?
  email         String?   @unique
  emailVerified DateTime?
  image         String?
  accounts      Account[]
  sessions            Session[]
  rooms               Room[]       @relation("HostRooms")
  sentInvitations     Invitation[] @relation("SentInvitations")
  receivedInvitations Invitation[] @relation("ReceivedInvitations")
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?  @db.Text
  access_token       String?  @db.Text
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?  @db.Text
  session_state      String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Room {
  id           Int           @id @default(autoincrement())
  name         String
  slug         String        @unique
  host         User          @relation("HostRooms", fields: [hostId], references: [id])
  hostId       String
  expiresAt    DateTime?
  callSessions CallSession[]
  invitations  Invitation[]
}

model CallSession {
  id         Int         @id @default(autoincrement())
  roomId     Int
  room       Room        @relation(fields: [roomId], references: [id], onDelete: Cascade)
  createdAt  DateTime    @default(now())
  recordings Recording[]
}

model Recording {
  id              Int         @id @default(autoincrement())
  sessionId       Int
  session         CallSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  participantName String
  fileUrl         String
}

model Invitation {
  id           String           @id @default(cuid())
  roomId       Int
  room         Room             @relation(fields: [roomId], references: [id], onDelete: Cascade)
  
  senderId     String
  sender       User             @relation("SentInvitations", fields: [senderId], references: [id])
  
  inviteeEmail String
  invitee      User             @relation("ReceivedInvitations", fields: [inviteeEmail], references: [email])
  
  status       InvitationStatus @default(PENDING)
  createdAt    DateTime         @default(now())

  @@index([inviteeEmail])
}

enum InvitationStatus {
  PENDING
  ACCEPTED
  DECLINED
}
